{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Trusted local UI (shell webview): full core + the embedded-browser controls.",
  "webviews": ["shell"],
  "permissions": [
    "core:default",
    "opener:default",
    "allow-open-dapp",
    "allow-set-dapp-bounds",
    "allow-hide-dapp",
    "allow-close-dapp",
    "allow-set-active-chain",
    "allow-get-active-chain",
    "allow-get-chains",
    "allow-add-chain",
    "allow-update-chain",
    "allow-remove-chain",
    "allow-vault-status",
    "allow-create-vault",
    "allow-import-vault",
    "allow-unlock-vault",
    "allow-lock-vault",
    "allow-select-account",
    "allow-add-account"
  ]
}
