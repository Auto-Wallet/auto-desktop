{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Trusted local UI (shell webview): full core + the embedded-browser controls.",
  "webviews": ["shell"],
  "permissions": [
    "core:default",
    "opener:default",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "allow-open-dapp",
    "allow-set-dapp-bounds",
    "allow-sync-toast-overlay",
    "allow-sync-menu-overlay",
    "allow-resolve-dapp-dialog",
    "allow-reload-dapp",
    "allow-hide-dapp",
    "allow-close-dapp",
    "allow-open-external-url",
    "allow-node-rpc",
    "allow-wallet-send",
    "allow-set-active-chain",
    "allow-get-active-chain",
    "allow-get-close-behavior",
    "allow-set-close-behavior",
    "allow-check-for-update",
    "allow-get-activity",
    "allow-get-portfolio-history",
    "allow-record-portfolio-snapshot",
    "allow-get-defi-positions",
    "allow-okx-dex-supported-chains",
    "allow-okx-dex-tokens",
    "allow-okx-dex-quote",
    "allow-okx-dex-swap",
    "allow-okx-dex-approve-transaction",
    "allow-okx-dex-history",
    "allow-get-chains",
    "allow-add-chain",
    "allow-update-chain",
    "allow-remove-chain",
    "allow-vault-status",
    "allow-create-vault",
    "allow-import-vault",
    "allow-import-private-key",
    "allow-export-wallet-secret",
    "allow-unlock-vault",
    "allow-lock-vault",
    "allow-reset-vault",
    "allow-ledger-addresses",
    "allow-connect-ledger",
    "allow-select-account",
    "allow-expose-dapp-account",
    "allow-add-account",
    "allow-rename-wallet",
    "allow-delete-wallet"
  ]
}
