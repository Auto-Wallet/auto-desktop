{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Trusted local UI (shell webview): full core + the embedded-browser controls.",
  "webviews": ["shell"],
  "permissions": [
    "core:default",
    "opener:default",
    "allow-open-dapp",
    "allow-set-dapp-bounds",
    "allow-hide-dapp",
    "allow-close-dapp",
    "allow-open-external-url",
    "allow-node-rpc",
    "allow-wallet-send",
    "allow-set-active-chain",
    "allow-get-active-chain",
    "allow-get-close-behavior",
    "allow-set-close-behavior",
    "allow-check-for-update",
    "allow-get-activity",
    "allow-get-chains",
    "allow-add-chain",
    "allow-update-chain",
    "allow-remove-chain",
    "allow-vault-status",
    "allow-create-vault",
    "allow-import-vault",
    "allow-import-private-key",
    "allow-unlock-vault",
    "allow-lock-vault",
    "allow-reset-vault",
    "allow-ledger-addresses",
    "allow-connect-ledger",
    "allow-select-account",
    "allow-add-account",
    "allow-rename-wallet",
    "allow-delete-wallet"
  ]
}
