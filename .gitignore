# Key safety — NEVER commit real key material (密钥安全).
# The vault keystore lives in the OS app-data dir, not the repo, but guard against
# any stray secrets and only ever commit *.example placeholders.
.env
.env.*
!.env.example
*.key
*.keystore
keystore*.json
vault*.json
!vault*.example.json
secrets*.json
mnemonic*.txt
*.seed

# Local-only artifacts
/tmp-shots
ad-shots/
smoke-artifacts/
